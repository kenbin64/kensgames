{
  "manifold": "starfighter",
  "name": "Starfighter",
  "version": "1.0.0",
  "status": "production",
  "dimension": {
    "x": 2,
    "y": 30,
    "z": 60,
    "_note": "z = x*y = 2 players avg * 30 min avg = 60"
  },
  "entry": "game.html",
  "lobby": "lobby/",
  "substrates": {
    "core": "core.js",
    "input": "input.js",
    "audio": "audio.js",
    "music": "music.js",
    "manifold": "manifold.js",
    "geometry": "manifold_geometry_substrate.js",
    "audio_sub": "manifold_audio_substrate.js",
    "native": "manifold_native_substrate.js",
    "anpc": "anpc_manifold.js",
    "hive_queen": "hive_queen_manifold.js",
    "spectrum": "spectrum_manifold.js",
    "rendering": "3d.js",
    "progression": "progression.js",
    "music_comp": "music_compositor.js",
    "sfx_comp": "sfx_compositor.js",
    "phrase_comp": "phrase_compositor.js"
  },
  "manifold_bridge": {
    "entry_var": "window.__MANIFOLD__",
    "schema_version": "1.0",
    "exposes": [
      "missionState",
      "playerShip",
      "enemies",
      "score",
      "wave",
      "emotion"
    ]
  },
  "npc": {
    "type": "ANPC",
    "manifold": "anpc_manifold.js",
    "cognition": "anpc.js",
    "intents": "anpc-intents.js",
    "patterns": "anpc-patterns.js",
    "history": "anpc-history.js"
  },
  "server": {
    "type": "node",
    "entry": "starfighter/server.js"
  },
  "build": {
    "test_dir": "tests/",
    "assets": [
      "*.html",
      "*.js",
      "*.css",
      "assets/**",
      "downloads/**"
    ]
  },
  "deploy": {
    "target": "/var/www/kensgames.com/public/starfighter/",
    "type": "static_with_server"
  },
  "manifold_compatibility": {
    "bridge_included": false,
    "state_exposed": false,
    "postmessage_protocol": false,
    "todo": [
      "Include js/manifold_bridge.js in game.html",
      "Emit window.__MANIFOLD__ from core.js with missionState",
      "Wire postMessage events to ManifoldBridge.emit()",
      "Expose ANPC emotion substrate through bridge"
    ]
  }
}
