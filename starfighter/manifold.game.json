{
  "manifold": "starfighter",
  "name": "StarFighter",
  "version": "1.0.0",
  "status": "production",
  "dimension": {
    "x": 2,
    "y": 30,
    "z": 60,
    "_note": "z = x*y = 2 players avg * 30 min avg = 60"
  },
  "maxPlayers": 4,
  "recommendedPlayers": 4,
  "entry": "index.html",
  "substrates": {
    "bundle": "bundle.js",
    "codex": "codex.js",
    "codex_data": "codex_data.js",
    "enhance": "enhance.js",
    "input": "input.js",
    "intro": "intro.js",
    "multiplayer": "multiplayer.js"
  },
  "manifold_bridge": {
    "entry_var": "window.__MANIFOLD__",
    "schema_version": "1.0",
    "exposes": [
      "missionState",
      "playerShip",
      "enemies",
      "score",
      "wave",
      "emotion"
    ]
  },
  "server": {
    "type": "node",
    "entry": "starfighter/server.js"
  },
  "build": {
    "test_dir": "tests/",
    "assets": [
      "*.html",
      "*.js",
      "*.css",
      "assets/**",
      "downloads/**"
    ]
  },
  "deploy": {
    "target": "/var/www/kensgames.com/starfighter/",
    "type": "static_with_server"
  },
  "manifold_compatibility": {
    "bridge_included": false,
    "state_exposed": false,
    "postmessage_protocol": false,
    "todo": [
      "Include js/manifold_bridge.js in index.html",
      "Emit window.__MANIFOLD__ from core.js with missionState",
      "Wire postMessage events to ManifoldBridge.emit()",
      "Expose ANPC emotion substrate through bridge"
    ]
  }
}
