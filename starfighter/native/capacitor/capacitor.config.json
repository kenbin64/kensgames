{
  "appId": "com.kensgames.starfighter",
  "appName": "Starfighter",
  "webDir": "../../",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#000000"
    },
    "ScreenOrientation": {
      "defaultOrientation": "landscape"
    }
  },
  "android": {
    "allowMixedContent": true,
    "overrideUserAgent": "Starfighter-Native/1.0"
  },
  "ios": {
    "overrideUserAgent": "Starfighter-Native/1.0"
  }
}
