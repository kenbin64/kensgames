{
  "name": "starfighter-desktop",
  "version": "1.0.0",
  "description": "Starfighter — Desktop Edition",
  "main": "main.js",
  "author": {
    "name": "Kenneth Bingham",
    "email": "kenetics.art@gmail.com"
  },
  "homepage": "https://kensgames.com/starfighter",
  "repository": {
    "type": "git",
    "url": "https://github.com/kenbin64/starfighter"
  },
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "start:dev": "electron . --dev",
    "start:steam": "electron . --steam",
    "icons": "node make_icons.js",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --linux",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.kensgames.starfighter",
    "productName": "Starfighter",
    "copyright": "Copyright © 2026 Kenneth Bingham",
    "icon": "assets/icon",
    "asar": true,
    "compression": "maximum",
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*",
      "game/**/*"
    ],
    "extraFiles": [],
    "afterPack": "afterPack.js",
    "directories": {
      "output": "../downloads"
    },
    "win": {
      "artifactName": "Starfighter-Setup.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "squirrelWindows": {
      "iconUrl": "https://kensgames.com/starfighter/assets/textures/starfighterlogo.png",
      "loadingGif": "assets/icon256.png"
    },
    "mac": {
      "artifactName": "Starfighter.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.games"
    },
    "linux": {
      "artifactName": "Starfighter.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Game"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Starfighter"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  }
}
