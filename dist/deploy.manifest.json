{
  "_schema": "2.0",
  "_compiled": "2026-04-20T00:00:00.000Z",
  "portal": "kensgames-portal",
  "version": "1.5.0",
  "vps": {
    "host": "172.81.62.217",
    "user": "butterfly",
    "webroot": "/var/www/kensgames.com/public",
    "logs": "/var/www/kensgames.com/logs",
    "backups": "/var/www/backups",
    "nginx_site": "/etc/nginx/sites-available/kensgames.com",
    "nginx_reload": true
  },
  "processes": [
    {
      "name": "kensgames-auth",
      "entry": "server/index.js",
      "port": 3000,
      "runtime": "node",
      "cwd": "/home/butterfly/apps/kensgames-portal/manifold"
    },
    {
      "name": "kensgames-lobby",
      "entry": "server/lobby-server.js",
      "port": 8765,
      "runtime": "node",
      "protocol": "websocket",
      "cwd": "/home/butterfly/apps/kensgames-portal/manifold"
    }
  ],
  "deploy_script": "deploy.sh",
  "steps": [
    {
      "step": "portal_root",
      "files": [
        "index.html",
        "portal.html",
        "manifold.html",
        "arcade.css",
        "arcade.js",
        "lounge.html",
        "discover.html",
        "showcase.html",
        "admin.html",
        "admin.js",
        "gyroid.js",
        "sitemap.xml",
        "manifold.portal.json",
        "substrates.json"
      ],
      "destination": "/var/www/kensgames.com/public/",
      "type": "copy"
    },
    {
      "step": "shared_assets",
      "source_dirs": [
        "js/",
        "css/",
        "lib/",
        "assets/",
        "shared/",
        "dist/"
      ],
      "destination": "/var/www/kensgames.com/public/",
      "type": "rsync",
      "excludes": [
        "node_modules/",
        ".git/"
      ]
    },
    {
      "step": "auth_pages",
      "source_dirs": [
        "login/",
        "register/",
        "forgot-password/",
        "reset-password/",
        "verify-email/",
        "invite/",
        "invited/",
        "tos/",
        "player/",
        "social/",
        "lobby/",
        "play/"
      ],
      "destination": "/var/www/kensgames.com/public/",
      "type": "rsync"
    },
    {
      "step": "gallery",
      "source_dirs": [
        "gallery/"
      ],
      "destination": "/var/www/kensgames.com/public/",
      "type": "rsync"
    },
    {
      "step": "admin_panel",
      "source_dirs": [
        "admin/"
      ],
      "destination": "/var/www/kensgames.com/public/",
      "type": "rsync"
    },
    {
      "step": "games",
      "source_dirs": [
        "fasttrack/",
        "brickbreaker3d/",
        "starfighter/",
        "assemble/",
        "4dtictactoe/",
        "chomp/",
        "dungeon/",
        "geowars/",
        "racer/",
        "siege/"
      ],
      "destination": "/var/www/kensgames.com/public/",
      "type": "rsync",
      "excludes": [
        "*.test.js",
        "*.sh",
        "manifold.game.json"
      ]
    },
    {
      "step": "server",
      "source_dirs": [
        "server/"
      ],
      "destination": "/var/www/kensgames.com/public/server/",
      "type": "rsync",
      "excludes": [
        "node_modules/"
      ],
      "note": "Server runs from source; webroot copy kept in sync"
    },
    {
      "step": "post_deploy",
      "commands": [
        "pm2 restart kensgames-auth --update-env",
        "pm2 restart kensgames-lobby --update-env",
        "nginx -t && nginx -s reload"
      ],
      "type": "shell"
    }
  ],
  "excludes_global": [
    ".git/",
    ".github/",
    "engine/",
    "node_modules/",
    "*.sh",
    "*.md",
    "*.pdf",
    "*.test.js",
    ".gitignore",
    "server/db.js.bak",
    "tools/",
    "helix.sh"
  ],
  "key_files": {
    "auth_server": "server/index.js",
    "lobby_server": "server/lobby-server.js",
    "database": "server/kensgames.db",
    "game_registry": "shared/game-registry.json",
    "nginx_config": "docs/nginx-kensgames.conf",
    "lobby_substrate": "js/kg_lobby.js",
    "gate_substrate": "js/kg_gate.js",
    "access_status": "js/access_status.js"
  }
}
}
