        "register/",
        "forgot-password/",
        "reset-password/",
        "verify-email/"
      ],
      "destination": "/var/www/kensgames.com",
      "type": "rsync"
    },
    {
      "step": "deploy_game_fasttrack",
      "source": "fasttrack/",
