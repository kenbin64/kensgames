      "can_enter_from_holding": false,
      "can_exit_bullseye": true,
      "is_royal": true
    },
    "K": {
      "x": 2,
      "y": 13,
      "z": 26,
      "movement": 1,
      "direction": "clockwise",
      "extra_turn": true,
      "can_enter_from_holding": false,
      "can_exit_bullseye": true,
      "is_royal": true
    },
    "JOKER": {
      "x": 2,
      "y": 14,
      "z": 28,
      "movement": 1,
      "direction": "clockwise",
      "extra_turn": true,
      "can_enter_from_holding": true,
      "can_exit_bullseye": false,
      "is_special": true,
      "is_wild": true
    }
  },
  "rules": [
    {
      "id": "MOV_CLOCKWISE",
      "x": 3,
      "y": 1,
      "z": 3,
      "category": "movement",
      "desc": "All movement is clockwise except Card 4 (counter-clockwise).",
      "assertion": "card.direction === 'counter_clockwise' ? movingBackward : !movingBackward",
      "provenance": [
        "unified_rules",
        "game_spec.json",
        "rules_substrate.MOVE_001",
        "board_manifold.R_DIRECTION",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "MOV_NO_LAND_OWN",
      "x": 3,
      "y": 2,
      "z": 6,
      "category": "movement",
      "desc": "A peg cannot land on its own peg.",
      "assertion": "!ctx.landsOnOwnPeg",
      "provenance": [
        "unified_rules",
        "game_spec.json",
        "rules_substrate.MOVE_002",
        "board_manifold.R_NO_PASS_OWN",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "MOV_NO_PASS_OWN",
      "x": 3,
      "y": 3,
      "z": 9,
      "category": "movement",
      "desc": "A peg cannot pass over its own peg on the outer rim, FT ring, or safe zone.",
      "assertion": "!ctx.pathBlockedByOwnPeg",
      "provenance": [
        "unified_rules",
        "game_spec.json",
        "rules_substrate.MOVE_002",
        "board_manifold.R_NO_PASS_OWN",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "MOV_EXACT_COUNT",
      "x": 3,
      "y": 4,
      "z": 12,
      "category": "movement",
      "desc": "Step count must equal card movement value (no over- or under-counting).",
      "assertion": "ctx.steps === ctx.card.movement || (ctx.card.rank==='6' && ctx.moveType==='enter' && ctx.steps===0) || (ctx.card.rank==='7' && ctx.isSplit)",
      "provenance": [
        "unified_rules",
        "game_spec.json"
      ]
    },
    {
      "id": "CIR_OWN_FT",
      "x": 4,
      "y": 1,
      "z": 4,
      "category": "circuit",
      "desc": "Touching or landing on own FT hole completes the circuit.",
      "assertion": "ctx.peg.passes(ownFtHole) || ctx.peg.lands(ownFtHole) ==> peg.completedCircuit = true",
      "provenance": [
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "CIR_SAFE_ENTRANCE",
      "x": 4,
      "y": 2,
      "z": 8,
      "category": "circuit",
      "desc": "Touching or passing safe-zone-entrance hole (outer-{p}-8) completes the circuit.",
      "assertion": "ctx.peg.passes('outer-'+p+'-8') || ctx.peg.lands('outer-'+p+'-8') ==> peg.completedCircuit = true",
      "provenance": [
        "user_directive_2026-04-25",
        "unified_rules.card_4.backward_past_safe_entry_satisfies_circuit"
      ]
    },
    {
      "id": "CIR_BACKWARD_4",
      "x": 4,
      "y": 3,
      "z": 12,
      "category": "circuit",
      "desc": "Card 4 landing on or past own safe-zone-entrance going backward also completes circuit.",
      "assertion": "ctx.movingBackward && (ctx.lands('outer-'+p+'-8') || ctx.passes('outer-'+p+'-8')) ==> peg.completedCircuit = true",
      "provenance": [
        "unified_rules.card_4.backward_past_safe_entry_satisfies_circuit",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "CUT_ON_LANDING",
      "x": 5,
      "y": 1,
      "z": 5,
      "category": "cut",
      "desc": "Landing on an opponent peg on the final step of a move cuts that peg.",
      "assertion": "ctx.landsOnOpponent && ctx.isFinalStep ==> opponent.peg.sentToHolding",
      "provenance": [
        "unified_rules",
        "game_spec.json",
        "rules_substrate.CUT_001",
        "board_manifold.R_CUT_OPPONENT",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "CUT_DEST_HOLDING",
      "x": 5,
      "y": 2,
      "z": 10,
      "category": "cut",
      "desc": "Cut peg returns to any open hole in opponent's holding area.",
      "assertion": "cut.destination = first_open(opponent.holding)",
      "provenance": [
        "unified_rules",
        "game_spec.json",
        "rules_substrate.CUT_001",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "CUT_DEST_HOME_FALLBACK",
      "x": 5,
      "y": 3,
      "z": 15,
      "category": "cut",
      "desc": "If opponent's holding area is full, cut peg returns to opponent's home/winner hole.",
      "assertion": "all_full(opponent.holding) ==> cut.destination = opponent.home",
      "provenance": [
        "unified_rules",
        "game_spec.json",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "CUT_SAFE_ZONES",
      "x": 5,
      "y": 4,
      "z": 20,
      "category": "cut",
      "desc": "Cannot cut pegs in holding, bullseye, or safe zone.",
      "assertion": "destRules.canBeCut === true",
      "provenance": [
        "unified_rules",
        "rules_substrate.CUT_002",
        "board_manifold.R_CUT_SAFE_ZONES",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "BULL_ENTRY_FROM_FT",
      "x": 6,
      "y": 1,
      "z": 6,
      "category": "bullseye_entry",
      "desc": "Bullseye can only be entered from an FT hole.",
      "assertion": "moveType==='enter_bullseye' ==> from(path).startsWith('ft-')",
      "provenance": [
        "user_directive_2026-04-25",
        "rules_substrate.MOVE_005"
      ]
    },
    {
      "id": "BULL_ENTRY_1STEP_FT",
      "x": 6,
      "y": 2,
      "z": 12,
      "category": "bullseye_entry",
      "desc": "Peg already on FT can enter bullseye with any 1-step card (A, J, Q, K, Joker), as final step, clockwise.",
      "assertion": "peg.onFasttrack && card.movement===1 && card.direction==='clockwise' && lastStep==='center'",
      "provenance": [
        "user_directive_2026-04-25",
        "unified_rules.fasttrack.bullseye_entry_from_fasttrack"
      ]
    },
    {
      "id": "BULL_ENTRY_PENULTIMATE",
      "x": 6,
      "y": 3,
      "z": 18,
      "category": "bullseye_entry",
      "desc": "Peg not on FT may enter bullseye only if penultimate step lands on an FT hole and final step lands on bullseye, clockwise.",
      "assertion": "!peg.onFasttrack ==> path.length>=2 && path[-2].startsWith('ft-') && path[-1]==='center' && !movingBackward",
      "provenance": [
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "BULL_NO_BACKWARD",
      "x": 6,
      "y": 4,
      "z": 24,
      "category": "bullseye_entry",
      "desc": "Cannot enter bullseye going counter-clockwise (Card 4).",
      "assertion": "!(card.rank==='4' && lastStep==='center')",
      "provenance": [
        "unified_rules",
        "rules_substrate.CARD_004",
        "board_manifold.R_BACKWARD_RESTRICTED",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "BULL_MAX_ONE_PEG",
      "x": 6,
      "y": 5,
      "z": 30,
      "category": "bullseye_entry",
      "desc": "Bullseye holds at most one peg at a time.",
      "assertion": "count(pegs.at('center')) <= 1",
      "provenance": [
        "unified_rules.bullseye.while_inside",
        "rules_substrate.MOVE_005"
      ]
    },
    {
      "id": "BULL_EXIT_JQK_ONLY",
      "x": 7,
      "y": 1,
      "z": 7,
      "category": "bullseye_exit",
      "desc": "Only J, Q, K can exit the bullseye. Ace and Joker CANNOT.",
      "assertion": "card.rank in ['J','Q','K']",
      "provenance": [
        "unified_rules",
        "board_manifold.R_BULLSEYE_EXIT",
        "rules_substrate.MOVE_005",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "BULL_EXIT_TARGET",
      "x": 7,
      "y": 2,
      "z": 14,
      "category": "bullseye_exit",
      "desc": "Default exit destination = player's own FT hole.",
      "assertion": "exit.target = 'ft-'+playerIdx",
      "provenance": [
        "unified_rules",
        "game_spec.json",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "BULL_EXIT_FALLBACK",
      "x": 7,
      "y": 3,
      "z": 21,
      "category": "bullseye_exit",
      "desc": "If own FT hole is occupied by own peg, walk counter-clockwise through FT ring to first FT hole not occupied by own peg.",
      "assertion": "while ownPegOn(target): target = ftRing.prev(target)",
      "provenance": [
        "unified_rules.bullseye.if_own_ft_occupied",
        "game_spec.json",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "BULL_EXIT_TO_OUTER_RIM",
      "x": 7,
      "y": 4,
      "z": 28,
      "category": "bullseye_exit",
      "desc": "After bullseye exit, peg occupies the FT hole's outer-rim position; peg does NOT regain FastTrack status. Peg continues clockwise on the outer rim.",
      "assertion": "exit ==> peg.onFasttrack = false; peg.holeId = 'outer-'+ftIdx+'-1'",
      "provenance": [
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "BULL_EXIT_CUT_OPP",
      "x": 7,
      "y": 5,
      "z": 35,
      "category": "bullseye_exit",
      "desc": "If exit destination has an opponent peg, cut them per CUT_ON_LANDING / CUT_DEST_* rules.",
      "assertion": "opponentOn(target) ==> apply(CUT_ON_LANDING)",
      "provenance": [
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "FT_ENTRY_EXACT",
      "x": 8,
      "y": 1,
      "z": 8,
      "category": "fasttrack",
      "desc": "FT entry: exact landing on an FT hole as the final step of a clockwise move.",
      "assertion": "lastStep.startsWith('ft-') && !movingBackward && ctx.isFinalStep ==> peg.onFasttrack = true",
      "provenance": [
        "unified_rules",
        "game_spec.json",
        "rules_substrate.MOVE_004",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "FT_NO_BACKWARD_ENTRY",
      "x": 8,
      "y": 2,
      "z": 16,
      "category": "fasttrack",
      "desc": "Cannot enter FastTrack going backward. Card 4 landing on an FT hole does NOT confer FT status.",
      "assertion": "movingBackward && lastStep.startsWith('ft-') ==> peg.onFasttrack = false (peg stays on outer rim)",
      "provenance": [
        "unified_rules",
        "rules_substrate.MOVE_004",
        "board_manifold.R_BACKWARD_RESTRICTED",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "FT_RING_CLOCKWISE",
      "x": 8,
      "y": 3,
      "z": 24,
      "category": "fasttrack",
      "desc": "Inner FT ring is traversed clockwise only.",
      "assertion": "ftRing.direction === 'clockwise'",
      "provenance": [
        "unified_rules",
        "game_spec.json",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "FT_NO_PASS_OWN_FT",
      "x": 8,
      "y": 4,
      "z": 32,
      "category": "fasttrack",
      "desc": "A peg on the FT ring cannot pass its own FT hole; it must exit there to its home stretch.",
      "assertion": "peg.onFasttrack && nextHop crosses ownFtHole ==> force exit at ownFtHole",
      "provenance": [
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "FT_NO_JUMP_TO_NEXT",
      "x": 8,
      "y": 5,
      "z": 40,
      "category": "fasttrack",
      "desc": "A peg cannot jump from its own FT hole to the next player's FT hole. (Bug fix: bullseye exit must not allow this.)",
      "assertion": "exit_target !== nextPlayer.ftHole",
      "provenance": [
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "FT_LOSS_ON_4",
      "x": 8,
      "y": 6,
      "z": 48,
      "category": "fasttrack",
      "desc": "Drawing a 4 ends FastTrack status for ALL of the player's pegs currently on FT. Rationale: the player may choose any peg to move backward 4 — even a non-FT peg — and any such choice constitutes 'choosing a move besides traversing FT,' which forfeits FT for every FT peg. Treating Card 4 as a blanket strip avoids ambiguity about which peg was moved.",
      "assertion": "card.rank==='4' && player.has_pegs_on_ft ==> all_player_ft_pegs.onFasttrack = false",
      "provenance": [
        "unified_rules.fasttrack.losing_fasttrack.on_4_card",
        "rules_substrate.SPECIAL_003",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "FT_LOSS_ON_NON_FT_MOVE",
      "x": 8,
      "y": 7,
      "z": 56,
      "category": "fasttrack",
      "desc": "Any move that does not traverse FT with an FT peg ends FT status for ALL of that player's FT pegs at end of turn.",
      "assertion": "moved_non_ft_peg && player.had_ft_pegs ==> at_end_of_turn: all_player_ft_pegs.onFasttrack = false",
      "provenance": [
        "unified_rules.fasttrack.losing_fasttrack.on_non_ft_move",
        "rules_substrate.SPECIAL_003",
        "user_directive_2026-04-25"
      ]
    },
    {
      "id": "FT_LOSS_VOLUNTARY_EXIT",
      "x": 8,
      "y": 8,
      "z": 64,
      "category": "fasttrack",
      "desc": "Voluntary move from FT hole onto outer rim ends FT status for that peg.",
      "assertion": "fromFtHole && toOuterRimNonFt ==> peg.onFasttrack = false",
      "provenance": [
