{
  "manifold": "brickbreaker3d",
  "name": "BrickBreaker 3D",
  "version": "1.0.0",
  "status": "production",
  "dimension": {
    "x": 2,
    "y": 22,
    "z": 44,
    "_note": "z = x*y = 2 players avg * 22 min avg = 44"
  },
  "entry": "index.html",
  "lobby": "lobby.html",
  "substrates": {
    "physics": "brickbreaker_manifold_substrate.js:PhysicsLens",
    "graphics": "brickbreaker_manifold_substrate.js:GraphicsLens",
    "audio": "brickbreaker_manifold_substrate.js:AudioLens",
    "score": "brickbreaker_manifold_substrate.js:ScoreLens",
    "game_state": "brickbreaker_manifold_substrate.js:GameStateLens"
  },
  "manifold_bridge": {
    "entry_var": "window.__MANIFOLD__",
    "schema_version": "1.0",
    "exposes": [
      "level",
      "score",
      "lives",
      "ballPosition",
      "brickGrid"
    ]
  },
  "physics": {
    "model": "golden_ratio_speed",
    "_note": "Speed boost per brick layer uses golden ratio φ ≈ 1.618"
  },
  "params": {
    "_note": "Tunable constants yielded to game.js at load (manifold-first; no hardcoded duplicates).",
    "phi": 1.618,
    "ball_radius": 1,
    "paddle_radius": 4.5,
    "paddle_thickness": 0.85,
    "speed_easy_phi": 0.25,
    "speed_hard_phi": 0.4,
    "speed_multi_phi": 0.3,
    "min_ball_speed_phi": 0.22,
    "max_ball_speed_phi": 0.85,
    "arena_height": 50,
    "lives_solo": 5,
    "reflection_resolution": 128,
    "reflection_update_every": 8
  },
  "build": {
    "assets": [
      "*.html",
      "*.js",
      "assets/**"
    ]
  },
  "deploy": {
    "target": "/var/www/kensgames.com/brickbreaker3d/",
    "type": "static"
  },
  "manifold_compatibility": {
    "bridge_included": true,
    "state_exposed": true,
    "postmessage_protocol": true,
    "substrate": "brickbreaker_manifold_substrate.js"
  }
}
