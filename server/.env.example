# KensGames Auth Server — environment variables
# Copy this file to .env and fill in real values

# JWT signing key (required)
JWT_SECRET=change-me-use-a-long-random-string

# Cloudflare Turnstile secret key (required in production)
# Get from https://dash.cloudflare.com/?to=/:account/turnstile
# Site key (public, already in HTML): 0x4AAAAAAC_uN7CPKfVyy0fj
TURNSTILE_SECRET=your-turnstile-secret-key-here

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=smtp-password
SMTP_FROM=noreply@kensgames.com

# OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Node environment
NODE_ENV=production
PORT=3000
